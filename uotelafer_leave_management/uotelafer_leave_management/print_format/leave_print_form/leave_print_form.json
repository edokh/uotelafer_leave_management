 "html": "<div style=\"text-align:center; margin-bottom:20px;\">\r\n    <img src=\"/files/uot_logo.jpg\" alt=\"{{ _('Company Logo') }}\" \r\n         style=\"height:80px; margin-bottom:10px; display:block; margin-left:auto; margin-right:auto;\">\r\n    <h2>{{ _('University Of Telafer') }}</h2>\r\n    <h4>{{ _('Leave Application Form') }}</h4>\r\n    <hr>\r\n</div>\r\n\r\n<table style=\"width:100%; border-collapse:collapse; margin-bottom:20px; border:1px solid black;\">\r\n    <tr>\r\n        <td colspan=\"4\" style=\"font-weight:bold; font-size:15pt; border:1px solid black; text-align:center;\">\r\n            {{ _('Employee Info') }}\r\n        </td>\r\n    </tr>\r\n\r\n    <tr>\r\n        <td style=\"width:30%; font-weight:bold; border:1px solid black;\">{{ _('Employee Name') }}:</td>\r\n        <td style=\"border:1px solid black;\">{{ doc.employee_fullname }}</td>\r\n        \r\n        <td style=\"font-weight:bold; border:1px solid black;\">{{ _('Department') }}:</td>\r\n        <td style=\"border:1px solid black;\">{{ doc.department }}</td>\r\n    </tr>\r\n    \r\n    <tr>\r\n        <td style=\"font-weight:bold; border:1px solid black;\">{{ _('From Date') }}:</td>\r\n        <td style=\"border:1px solid black;\">{{ doc.from_date }}</td>\r\n        \r\n        <td style=\"font-weight:bold; border:1px solid black;\">{{ _('To Date') }}:</td>\r\n        <td style=\"border:1px solid black;\">{{ doc.to_date }}</td>\r\n    </tr>\r\n    <tr>\r\n        <td style=\"font-weight:bold; border:1px solid black;\">{{ _('Days') }}:</td>\r\n        <td style=\"border:1px solid black;\">{{ doc.days }}</td>\r\n        \r\n        <td style=\"font-weight:bold; border:1px solid black;\">{{ _('Leave Type') }}:</td>\r\n        <td style=\"border:1px solid black;\">{{ doc.leave_type }}</td>\r\n    </tr>\r\n    <tr>\r\n        <td style=\"font-weight:bold; border:1px solid black;\">{{ _('Reason') }}:</td>\r\n        <td style=\"border:1px solid black;\" colspan=\"3\">{{ doc.reason }}</td>\r\n    </tr>\r\n</table>\r\n<br/>\r\n\r\n<table style=\"width:100%; border-collapse:collapse; margin-bottom:20px; border:1px solid black;\">\r\n    <tr>\r\n        <td colspan=\"4\" style=\"font-weight:bold; font-size:15pt; border:1px solid black; text-align:center;\">\r\n            {{ _('Official approvals') }}\r\n        </td>\r\n    </tr>\r\n\r\n    <tr>\r\n        <td style=\"width:30%; font-weight:bold; border:1px solid black;\">{{ _('Head Department') }}</td>\r\n        <td style=\"border:1px solid black;\">{{ doc.supervisor }}</td>\r\n    </tr>\r\n    \r\n    <tr>\r\n        <td style=\"font-weight:bold; border:1px solid black;\">{{ _('Leave Status') }}</td>\r\n        <td style=\"border:1px solid black;\">{{ doc.status }}</td>\r\n    </tr>\r\n</table>\r\n",
