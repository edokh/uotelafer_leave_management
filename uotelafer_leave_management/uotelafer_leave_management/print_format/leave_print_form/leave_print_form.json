 "html": "<div dir=\"rtl\" style=\"\r\n    border:1px solid black;\r\n    padding:8px;\r\n    font-family:Tahoma;\r\n    font-size:11px;\r\n    width:100%;\r\n\">\r\n\r\n    <!-- Header -->\r\n    <table style=\"width:100%; border-collapse:collapse; margin-bottom:5px;\">\r\n        <tr>          \r\n            <td style=\"text-align:center;\">\r\n                <div style=\"font-weight:bold;\">\u062c\u0627\u0645\u0639\u0629 \u062a\u0644\u0639\u0641\u0631</div>\r\n                <div style=\"font-weight:bold; margin-top:3px;\">\r\n                \u0627\u0633\u062a\u0645ssss\u0627\u0631\u0629 \u0627\u0644\u0627\u062c\u0632\u0627\u0629               \r\n                </div>\r\n            </td>\r\n            <td style=\"width:50%;\"></td>          \r\n            <td style=\"width:15%; text-align:left;\">\r\n                <img src=\"/files/398187124_832924115292771_8632611931367621524_n.png\" style=\"height:5rem;\">\r\n            </td>\r\n        </tr>\r\n    </table>\r\n\r\n\r\n    <!-- Instructions -->\r\n    <table style=\"width:100%; border-collapse:collapse; margin-bottom:5px;\">\r\n             <tr>\r\n\r\n        </tr>\r\n        <tr>\r\n            \r\n            <!-- Right box -->\r\n            <td style=\"\r\n                width:30%;\r\n                border:1px solid black;\r\n                text-align:center;\r\n                vertical-align:middle;\r\n                font-weight:bold;\r\n                padding:10px;\r\n            \">\r\n                \u062a\u0639\u0644\u064a\u0645\u0627\u062a \u0627\u0644\u062a\u0642\u062f\u064a\u0645 \u0644\u0644\u062d\u0635\u0648\u0644 \u0639\u0644\u0649 \u0627\u0644\u0625\u062c\u0627\u0632\u0629\r\n            </td>\r\n\r\n            <!-- Left box -->\r\n            <td style=\"\r\n                border:1px solid black;\r\n                padding:6px;\r\n                line-height:1.8;\r\n            \">\r\n                1- \u064a\u062a\u0645 \u062a\u0642\u062f\u064a\u0645 \u0627\u0644\u0637\u0644\u0628 \u062d\u0633\u0628 \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u0627\u062a \u0623\u0639\u0644\u0627\u0647.\r\n                <br>\r\n                2- \u064a\u0639\u062a\u0645\u062f \u0645\u0646 \u0627\u0644\u0645\u0633\u0624\u0648\u0644 \u0627\u0644\u0645\u0628\u0627\u0634\u0631.\r\n                <br>\r\n                3- \u064a\u062a\u0645 \u062a\u0646\u0638\u064a\u0645 \u0627\u0644\u0623\u0648\u0644\u064a\u0627\u062a \u0628\u0634\u0643\u0644 \u0648\u0627\u0636\u062d.\r\n                <br>\r\n                4- \u064a\u0631\u0641\u0639 \u0625\u0644\u0649 \u0634\u0639\u0628\u0629 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629.\r\n                <br>\r\n                5- \u064a\u062d\u0642 \u0644\u0644\u0645\u0648\u0638\u0641 \u0645\u062a\u0627\u0628\u0639\u0629 \u0627\u0644\u0637\u0644\u0628.\r\n            </td>\r\n\r\n        </tr>\r\n    </table>\r\n\r\n\r\n\r\n    <!-- Employee Info -->\r\n    <table style=\"width:100%; border-collapse:collapse; margin-bottom:5px;\">\r\n\r\n        <tr>\r\n            <td colspan=\"4\" style=\"\r\n                border:1px solid black;\r\n                text-align:center;\r\n                font-weight:bold;\r\n                padding:4px;\r\n            \">\r\n                 \u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u0648\u0638\u0641 \\\u0640\u0629\r\n            </td>\r\n        </tr>\r\n\r\n        <tr>\r\n            <td style=\"border:1px solid black; padding:4px;\">\u0627\u0633\u0645 \u0627\u0644\u0645\u0648\u0638\u0641</td>\r\n            <td style=\"border:1px solid black; padding:4px;\">\r\n                {{ doc.employee_fullname }}\r\n            </td>\r\n\r\n            <td style=\"border:1px solid black; padding:4px;\">\u0627\u0644\u0642\u0633\u0645</td>\r\n            <td style=\"border:1px solid black; padding:4px;\">\r\n                {{ doc.dep }}\r\n            </td>\r\n        </tr>\r\n\r\n        <tr>\r\n\r\n            <td style=\"border:1px solid black; padding:4px;\">\u0646\u0648\u0639 \u0627\u0644\u0625\u062c\u0627\u0632\u0629</td>\r\n            <td style=\"border:1px solid black; padding:4px;\">\r\n                {{ frappe.db.get_value(\"Leave Type\", doc.leave_type, \"leave_type\") }}\r\n            </td>\r\n            <td style=\"border:1px solid black; padding:4px;\">\u0645\u062f\u0629 \u0627\u0644\u0625\u062c\u0627\u0632\u0629</td>\r\n            <td style=\"border:1px solid black; padding:4px;\">\r\n                {{ doc.days }}\r\n            </td>\r\n        </tr>\r\n\r\n        <tr>\r\n            <td style=\"border:1px solid black; padding:4px;\">\u0645\u0646 \u062a\u0627\u0631\u064a\u062e</td>\r\n            <td style=\"border:1px solid black; padding:4px;\">\r\n                {{ doc.from_date }}\r\n            </td>\r\n\r\n            <td style=\"border:1px solid black; padding:4px;\">\u0625\u0644\u0649 \u062a\u0627\u0631\u064a\u062e</td>\r\n            <td style=\"border:1px solid black; padding:4px;\">\r\n                {{ doc.to_date }}\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n          <td style=\"border:1px solid black; padding:4px;\">\r\n            \u0633\u0628\u0628 \u0627\u0644\u0625\u062c\u0627\u0632\u0629\r\n          </td>\r\n          <td style=\"border:1px solid black; padding:4px;\" colspan=\"3\">\r\n            {{ doc.reason}}\r\n          </td>\r\n        </tr>\r\n        <tr>\r\n          <td style=\"border:1px solid black; padding:4px;\">\r\n            \u0627\u0633\u0645 \u0627\u0644\u0645\u0648\u0638\u0641 \u0627\u0644\u062b\u0644\u0627\u062b\u064a \u0627\u0644\u0628\u062f\u064a\u0644\r\n          </td>\r\n          <td style=\"border:1px solid black; padding:4px;\" colspan=\"3\">\r\n            {{doc.alternative_employee}}\r\n          </td>\r\n        </tr>\r\n    </table>\r\n\r\n\r\n\r\n    <!-- Applicant -->\r\n    <table style=\"width:100%; border-collapse:collapse; margin-bottom:5px;\">\r\n\r\n        <tr>\r\n            <td colspan=\"4\" style=\"\r\n                border:1px solid black;\r\n                text-align:center;\r\n                font-weight:bold;\r\n                padding:4px;\r\n            \">\r\n                \u0628\u064a\u0627\u0646\u0627\u062a \u0645\u0642\u062f\u0645 \u0627\u0644\u0637\u0644\u0628\r\n            </td>\r\n        </tr>\r\n        \r\n        <tr>\r\n            <td style=\"border:1px solid black; padding:4px;\">\u0627\u0633\u0645 \u0645\u0642\u062f\u0645 \u0627\u0644\u0637\u0644\u0628</td>\r\n            <td style=\"border:1px solid black; padding:4px; width:25%;\">\r\n                \r\n            </td>\r\n\r\n            <td style=\"border:1px solid black; padding:4px;\" rowspan=\"2\">\u062a\u0648\u0642\u064a\u0639 \u0645\u0642\u062f\u0645 \u0627\u0644\u0637\u0644\u0628</td>\r\n            <td style=\"border:1px solid black; padding:4px; width:25%;\" rowspan=\"2\">\r\n               \r\n            </td>\r\n        </tr>\r\n         <tr >\r\n            <td style=\"border:1px solid black; padding:4px;\" >\u062a\u0627\u0631\u064a\u062e \u0645\u0642\u062f\u0645 \u0627\u0644\u0637\u0644\u0628</td>\r\n            <td style=\"border:1px solid black; padding:4px; width:25%;\">\r\n                \r\n            </td>\r\n        </tr>\r\n    </table>\r\n\r\n\r\n\r\n    <!-- Leave balances -->\r\n    <table style=\"width:100%; border-collapse:collapse; margin-bottom:5px;\">\r\n\r\n        <tr>\r\n            <td colspan=\"2\" style=\"\r\n                border:1px solid black;\r\n                text-align:center;\r\n                font-weight:bold;\r\n                padding:4px;\r\n            \">\r\n                \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629\r\n            </td>\r\n        </tr>\r\n\r\n        <tr>\r\n            <td style=\"\r\n                border:1px solid black;\r\n                height:70px;\r\n                padding:4px;\r\n            \">\r\n                \u0627\u0644\u0625\u062c\u0627\u0632\u0627\u062a \u0627\u0644\u0645\u062a\u0631\u0627\u0643\u0645\u0629:\r\n                <br><br>\r\n                \u0627\u0644\u0625\u062c\u0627\u0632\u0627\u062a \u062e\u0644\u0627\u0644 \u0627\u0644\u0634\u0647\u0631:\r\n                <br><br>\r\n                \u0627\u0644\u0625\u062c\u0627\u0632\u0627\u062a \u0627\u0644\u0632\u0645\u0646\u064a\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0634\u0647\u0631:\r\n            </td>\r\n\r\n            <td style=\"\r\n                border:1px solid black;\r\n                height:70px;\r\n                padding:4px;\r\n              width:50%\r\n            \">\r\n              \r\n              \u0627\u0644\u0627\u062c\u0627\u0632\u0627\u062a \u0627\u0644\u0645\u0631\u0636\u064a\u0629:\r\n              <br/><br/>\r\n              \u0627\u0644\u0627\u062c\u0627\u0632\u0627\u062a \u0627\u0644\u0645\u0631\u0636\u064a\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0634\u0647\u0631:\r\n            </td>\r\n        </tr>\r\n\r\n    </table>\r\n\r\n\r\n<!-- Signatures -->\r\n<table style=\"width:100%; border-collapse:collapse;\">\r\n    <tr>\r\n        <td colspan=\"2\" style=\"\r\n            border:1px solid black;\r\n            text-align:center;\r\n            font-weight:bold;\r\n            padding:4px;\r\n        \">\r\n            \u0627\u0644\u0645\u0648\u0627\u0641\u0642\u0627\u062a \u0627\u0644\u0631\u0633\u0645\u064a\u0629\r\n        </td>\r\n    </tr>\r\n    <tr>\r\n        <td style=\"\r\n            border:1px solid black;\r\n            text-align:center;\r\n            padding:5px;\r\n        \">\r\n            \u0627\u0644\u0645\u0633\u0624\u0648\u0644 \u0627\u0644\u0645\u0628\u0627\u0634\u0631 \u0639\u0644\u0649 \u0627\u0644\u0625\u062c\u0627\u0632\u0629\r\n        </td>\r\n        <td style=\"\r\n            border:1px solid black;\r\n            text-align:center;\r\n            padding:5px;\r\n            width:50%;\r\n        \">\r\n            \u0642\u0633\u0645 \u0634\u0624\u0648\u0646 \u0627\u0644\u062f\u064a\u0648\u0627\u0646\r\n        </td>\r\n    </tr>\r\n    <tr>\r\n        <!-- Added position: relative here so the stamp positions itself relative to this cell -->\r\n        <td style=\"\r\n            border:1px solid black;\r\n            height:85px;\r\n            vertical-align:top;\r\n            padding: 8px;\r\n            position: relative; \r\n        \">\r\n            <!-- Floating Square Stamp -->\r\n            <img src=\"/assets/uotelafer_leave_management/stamp.png\" style=\"\r\n                position: absolute;\r\n                top: 10px;\r\n                left: 1px;\r\n                width: 125px;\r\n                height: 125px;\r\n                object-fit: contain;\r\n                opacity: 0.85;\r\n                pointer-events: none;\r\n                z-index: 10;\r\n                  transform: rotate(90deg);\r\n\r\n            \"> \r\n\r\n            \u0627\u0644\u062a\u0648\u0642\u064a\u0639:\r\n            <br><br>\r\n            \u0627\u0644\u0623\u0633\u0645: {{ doc.supervisor or \"\" }}\r\n            <br><br>\r\n            \u0627\u0644\u062a\u0623\u0631\u064a\u062e:\r\n        </td>\r\n        <td style=\"\r\n            border:1px solid black;\r\n            text-align:center;\r\n            height:85px;\r\n            vertical-align:top;\r\n            padding-top:5px;\r\n            width:50%;\r\n        \">\r\n        </td>\r\n    </tr>\r\n</table>\r\n\r\n\r\n</div>",
